{
  "name": "@phyloref/phyx",
  "version": "1.2.1",
  "description": "Classes and methods that help read and manipulate components of Phyloreference Exchange (PHYX) format files",
  "keywords": [
    "phylogenetics",
    "phylogeny",
    "phylogenetic definitions",
    "clade definitions"
  ],
  "homepage": "https://phyloref.github.io/phyx.js/",
  "bugs": {
    "url": "https://github.com/phyloref/phyx.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phyloref/phyx.js.git"
  },
  "license": "MIT",
  "author": "Gaurav Vaidya <gaurav@ggvaidya.com>",
  "main": "src/index.js",
  "bin": {
    "phyx2owl": "bin/phyx2owl.mjs",
    "resolve": "bin/resolve.mjs"
  },
  "scripts": {
    "predocs": "cp CHANGELOG.md tutorials/CHANGELOG.md",
    "docs": "jsdoc --configure jsdoc.json",
    "postdocs": "rm -f tutorials/CHANGELOG.md && cp -r context docs/context",
    "generate-every-topology": "every-topology-testing/generate-topologies.js",
    "lint": "biome check",
    "phyx2owl": "node bin/phyx2owl.mjs",
    "resolve": "node bin/resolve.mjs",
    "posttest": "npm run lint",
    "test": "mocha --recursive"
  },
  "dependencies": {
    "jsonld": "^9.0.0",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "newick-js": "^1.2.1",
    "retus": "^1.1.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "chai": "^6.2.2",
    "clean-jsdoc-theme": "^4.3.0",
    "jsdoc": "^4.0.5",
    "mocha": "^11.7.5",
    "nodejs-file-downloader": "^4.13.0"
  }
}
